	// Master toggle for the nether_portal_invasion event
	netherPortalInvasionEnabled: true,
	// How often (in server ticks) the mod scans loaded chunks for active nether portals
	netherPortalInvasionScanIntervalTicks: 100,
	// Cooldown (in ticks) after an invasion ends before the same portal can trigger again
	netherPortalInvasionPortalCooldownTicks: 12000,
	// Probability (per scan) that an eligible portal triggers an invasion
	netherPortalInvasionTriggerChance: 0.05,
	// Minimum number of waves per invasion (inclusive)
	netherPortalInvasionMinWaves: 4,
	// Maximum number of waves per invasion (inclusive)
	netherPortalInvasionMaxWaves: 6,
	// Number of mobs in the first wave
	netherPortalInvasionFirstWaveSize: 2,
	// Additional mobs added per wave (linear scaling: wave_n = first + (n-1) * step)
	netherPortalInvasionWaveSizeStep: 1,
	// When enabled, the first mob of each wave acts as leader. Other wave members regroup around it whenever they stray too far. Followers in active combat are left alone, and mounted mobs' passengers are skipped.
	netherPortalInvasionGroupCohesionEnabled: true,
	// Distance (in blocks) beyond which a wave member is pulled back toward its leader
	netherPortalInvasionGroupCohesionRadius: 12,
