{
	// Whether mobs spawned by any encounter event can drop their equipment when killed.
	mobsDropEquipment: false,
	// Master toggle for the lightning_overcharge event
	lightningOverchargeEnabled: true,
	// Probability that a natural lightning bolt during a storm triggers the event
	lightningOverchargeChance: 0.05,
	// Minimum number of mobs spawned by the event (inclusive)
	lightningOverchargeGroupMin: 2,
	// Maximum number of mobs spawned by the event (inclusive)
	lightningOverchargeGroupMax: 5,
	// When enabled, the first mob of a group acts as leader and the others regroup around it whenever they stray too far. Followers in active combat are left alone.
	lightningOverchargeGroupCohesionEnabled: true,
	// Distance (in blocks) beyond which a follower is pulled back toward its leader
	lightningOverchargeGroupCohesionRadius: 12,
	// Weighted mob pool. Each entry: { id, weight, nbt?, label? }. 'nbt' is SNBT identical to the /summon command. Editable from the in-game config GUI.
